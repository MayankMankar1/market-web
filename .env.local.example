# Copy this file to .env.local and fill in real values once your Dodo
# Payments account is set up. Never commit .env.local — it's already in
# .gitignore by default from create-next-app.

# "test" while developing/testing, "live" once your Dodo store is activated
DODO_ENV=test

# Your extension's origin, so only it can call /api/verify-license.
# Find your extension ID at chrome://extensions (enable Developer mode).
ALLOWED_EXTENSION_ORIGIN=chrome-extension://your-extension-id-here

# The Dodo Payments checkout/payment link for your Pro plan.
# Create this in the Dodo dashboard once your product is set up, then
# paste the link here. Shown on the /pricing page.
NEXT_PUBLIC_DODO_CHECKOUT_URL=
